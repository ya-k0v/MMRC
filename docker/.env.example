# ========================
# MMRC Docker Configuration
# ========================

# General
NODE_ENV=production
LOG_LEVEL=info
SILENT_CONSOLE=false

# JWT Authentication
JWT_SECRET=your-secret-key-here-change-in-production
JWT_ACCESS_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=30d

# Server
SERVER_PORT=3000

# Database
WAL_CHECKPOINT_INTERVAL_MS=300000

# Night Optimization
NIGHT_OPT_START_HOUR=1
NIGHT_OPT_END_HOUR=5

# Resource Limits
JOB_RESERVE_CPU_PERCENT=30
JOB_RESERVE_MEMORY_MB=2048
JOB_MAX_SINGLE_JOB_PERCENT=70

# Stream Worker
STREAM_MAX_JOBS=100
STREAM_IDLE_TIMEOUT_MS=180000
RESTREAM_SEGMENT_DURATION=4
RESTREAM_PLAYLIST_SIZE=6

# Optimizer Worker (separate limits)
OPTIMIZER_CPU_PERCENT=50
OPTIMIZER_MEMORY_MB=4096
OPTIMIZER_MAX_SINGLE_JOB=80
OPTIMIZER_CPU_LIMIT=4.0
OPTIMIZER_MEMORY_LIMIT=8G

# Stream Worker (separate limits)
STREAMER_CPU_PERCENT=40
STREAMER_MEMORY_MB=2048
STREAMER_MAX_SINGLE_JOB=70
STREAMER_CPU_LIMIT=2.0
STREAMER_MEMORY_LIMIT=4G

# Nginx
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# LDAP (optional)
LDAP_URL=
LDAP_BIND_DN=
LDAP_SEARCH_BASE=
