# syntax=docker/dockerfile:1

FROM alpine:3.20

LABEL maintainer="ya-k0v"
LABEL description="MMRC - LibreOffice converter sidecar"

RUN apk add --no-cache \
    libreoffice-impress \
    ca-certificates \
    wget \
    bash \
    tini \
    && rm -rf /var/cache/apk/*

COPY docker/converter-entrypoint.sh /usr/local/bin/converter-entrypoint.sh
RUN chmod +x /usr/local/bin/converter-entrypoint.sh

ENTRYPOINT ["/sbin/tini", "--", "/usr/local/bin/converter-entrypoint.sh"]
CMD ["sleep", "infinity"]