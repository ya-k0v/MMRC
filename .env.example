# VideoControl Environment Variables
# Copy this file to .env and configure for your environment

# ============================================
# Server Configuration
# ============================================
# Port for the server (default: 3000)
# Note: Server listens only on 127.0.0.1, use Nginx as reverse proxy
PORT=3000

# Node environment (development/production)
NODE_ENV=production

# ============================================
# Security
# ============================================
# JWT Secret for token generation (REQUIRED for production!)
# Generate a secure secret: openssl rand -hex 64
# ⚠️ WARNING: Without this, tokens will be invalidated on server restart!
JWT_SECRET=your-secret-key-here-change-in-production

# JWT Token expiration times
JWT_ACCESS_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# Data Storage
# ============================================
# Root directory for all application data
# Default: ./data (local storage)
# For external disk: /mnt/videocontrol-data
DATA_ROOT=/mnt/videocontrol-data

# Content root path (can be changed via admin panel)
# Default: ${DATA_ROOT}/content or ./data/content
CONTENT_ROOT=/mnt/videocontrol-data/content

# ============================================
# Logging
# ============================================
# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Silent console output (true/false)
SILENT_CONSOLE=false

# ============================================
# FFmpeg / Streaming
# ============================================
# Path to ffmpeg binary (default: ffmpeg from PATH)
FFMPEG_PATH=ffmpeg

# Restream segment duration in seconds (default: 3)
RESTREAM_SEGMENT_DURATION=3

# Restream playlist size (default: 10)
RESTREAM_PLAYLIST_SIZE=10

# Stream restart delay in milliseconds (default: 5000)
RESTREAM_RESTART_DELAY_MS=5000

# Stream restart max attempts (default: 5)
STREAM_RESTART_MAX_ATTEMPTS=5

# Stream restart initial delay in milliseconds (default: 5000)
STREAM_RESTART_INITIAL_DELAY=5000

# Stream restart max delay in milliseconds (default: 60000)
STREAM_RESTART_MAX_DELAY=60000

# Stream circuit breaker threshold (default: 5)
STREAM_CIRCUIT_BREAKER_THRESHOLD=5

# Stream circuit breaker timeout in milliseconds (default: 300000)
STREAM_CIRCUIT_BREAKER_TIMEOUT=300000

# Stream cleanup interval in milliseconds (default: 300000)
STREAM_CLEANUP_INTERVAL=300000

# Maximum stream folder size in MB (default: 500)
STREAM_MAX_FOLDER_SIZE_MB=500

# Stream playlist max age in milliseconds (default: 30000)
STREAM_PLAYLIST_MAX_AGE=30000

# Enable stream source check (default: true)
STREAM_SOURCE_CHECK_ENABLED=true

# Stream source check timeout in milliseconds (default: 5000)
STREAM_SOURCE_CHECK_TIMEOUT=5000

# Maximum concurrent stream jobs (default: 100)
STREAM_MAX_JOBS=100

# Hung process timeout in milliseconds (default: 60000)
STREAM_HUNG_PROCESS_TIMEOUT=60000

# Stream idle timeout in milliseconds (default: 180000 = 3 minutes)
STREAM_IDLE_TIMEOUT_MS=180000
