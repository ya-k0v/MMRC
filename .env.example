# ========================================
# VideoControl 3.0.0 - Environment Variables
# ========================================
# Скопируйте этот файл в .env и настройте значения
# cp .env.example .env
# nano .env
#
# ВАЖНО: .env файл содержит секретные данные и не должен попадать в Git!
# ========================================

# ========================================
# ОСНОВНЫЕ НАСТРОЙКИ
# ========================================

# Режим работы (production | development)
NODE_ENV=production

# Порт сервера (по умолчанию: 3000)
# Сервер слушает только на 127.0.0.1, доступ через Nginx
PORT=3000

# Хост сервера (по умолчанию: 127.0.0.1)
# ВАЖНО: Не меняйте на 0.0.0.0 - используйте Nginx для внешнего доступа
HOST=127.0.0.1

# ========================================
# JWT АУТЕНТИФИКАЦИЯ
# ========================================

# Секретный ключ для JWT токенов (ОБЯЗАТЕЛЬНО!)
# Сгенерируйте новый ключ: openssl rand -hex 64
# Или через Node.js: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-key-here-CHANGE-THIS

# Время жизни access token (по умолчанию: 12h)
JWT_ACCESS_EXPIRES_IN=12h

# Время жизни refresh token (по умолчанию: 30d)
JWT_REFRESH_EXPIRES_IN=30d

# ========================================
# LDAP / AD АУТЕНТИФИКАЦИЯ
# ========================================
# ВАЖНО: LDAP теперь настраивается только через .env
# Если LDAP отключен или недоступен, локальная авторизация продолжает работать

# Включить LDAP (true | false)
LDAP_ENABLED=false

# URL LDAP сервера
# Примеры:
#   ldap://dc.company.local:389
#   ldaps://dc.company.local:636
LDAP_URL=

# Base DN для поиска пользователей
LDAP_BASE_DN=

# Bind DN и пароль (опционально)
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

# Фильтр и атрибут логина
LDAP_USER_FILTER=(sAMAccountName={username})
LDAP_USERNAME_ATTRIBUTE=sAMAccountName

# Область поиска: base | one | sub
LDAP_SEARCH_SCOPE=sub

# Автосоздание LDAP пользователей в локальной БД
LDAP_AUTO_CREATE_USERS=true

# Роль для новых LDAP пользователей: admin | speaker | hero_admin
LDAP_DEFAULT_ROLE=speaker

# Таймауты LDAP в миллисекундах
LDAP_CONNECT_TIMEOUT_MS=5000
LDAP_OPERATION_TIMEOUT_MS=5000

# Проверять TLS сертификат (true | false)
LDAP_TLS_REJECT_UNAUTHORIZED=true

# ========================================
# ЛОГИРОВАНИЕ
# ========================================

# Уровень логирования (off | debug | info | warning)
# off - отключить все логи
# debug - все логи
# info - информация и выше
# warning - только ошибки
LOG_LEVEL=info

# Отключить вывод в консоль (true | false)
# В production можно установить true, если логи пишутся только в файлы
SILENT_CONSOLE=false

# ========================================
# SQLITE БАЗА ДАННЫХ
# ========================================

# Интервал выполнения WAL checkpoint в миллисекундах (по умолчанию: 60000 = 1 минута)
# Проверяет размер WAL файла и выполняет checkpoint если > WAL_CHECKPOINT_THRESHOLD_MB
WAL_CHECKPOINT_INTERVAL_MS=60000

# Порог размера WAL файла в MB для выполнения checkpoint (по умолчанию: 100)
# Если WAL файл больше этого размера, выполняется checkpoint
WAL_CHECKPOINT_THRESHOLD_MB=100

# ========================================
# УПРАВЛЕНИЕ ФАЙЛАМИ
# ========================================

# Автоматическая очистка несуществующих файлов из БД при старте (true | false)
# Если true, при запуске сервера проверяются все файлы в БД и удаляются записи для несуществующих файлов
AUTO_CLEANUP_MISSING_FILES=false

# ========================================
# ХРАНИЛИЩЕ ДАННЫХ (УСТАРЕВШЕЕ)
# ========================================
# ВАЖНО: В версии 3.0.0 пути данных настраиваются через админ-панель
# Эти переменные используются только при первой инициализации
# После инициализации все пути берутся из config/app-settings.json

# Корневая директория данных (по умолчанию: /vid/videocontrol/data)
# Если указан и существует - используется для всех данных (content, streams, converted, logs, temp)
# Если не указан - используется локальная папка проекта
DATA_ROOT=

# Legacy: путь к контенту устройств (используйте DATA_ROOT вместо этого)
CONTENT_ROOT=

# ========================================
# СТРИМИНГ (HLS RESTREAM)
# ========================================

# Путь к FFmpeg (по умолчанию: ffmpeg из PATH)
FFMPEG_PATH=ffmpeg

# Длительность сегмента HLS в секундах (по умолчанию: 3)
RESTREAM_SEGMENT_DURATION=3

# Размер плейлиста HLS (количество сегментов, по умолчанию: 10)
RESTREAM_PLAYLIST_SIZE=10

# Порог удаления старых сегментов (по умолчанию: 5)
# Удаляются сегменты сверх playlistSize + hlsDeleteThreshold
RESTREAM_HLS_DELETE_THRESHOLD=5

# Задержка перед перезапуском стрима в миллисекундах (по умолчанию: 5000)
RESTREAM_RESTART_DELAY_MS=5000

# Максимальное количество попыток перезапуска стрима (по умолчанию: 5)
STREAM_RESTART_MAX_ATTEMPTS=5

# Начальная задержка перед перезапуском в миллисекундах (по умолчанию: 5000)
STREAM_RESTART_INITIAL_DELAY=5000

# Максимальная задержка перед перезапуском в миллисекундах (по умолчанию: 60000)
STREAM_RESTART_MAX_DELAY=60000

# Порог для circuit breaker (количество ошибок, по умолчанию: 5)
STREAM_CIRCUIT_BREAKER_THRESHOLD=5

# Таймаут circuit breaker в миллисекундах (по умолчанию: 300000 = 5 минут)
STREAM_CIRCUIT_BREAKER_TIMEOUT=300000

# Интервал очистки неиспользуемых стримов в миллисекундах (по умолчанию: 300000 = 5 минут)
STREAM_CLEANUP_INTERVAL=300000

# Максимальный размер папки стрима в MB (по умолчанию: 500)
STREAM_MAX_FOLDER_SIZE_MB=500

# Максимальный возраст плейлиста в миллисекундах (по умолчанию: 30000 = 30 секунд)
STREAM_PLAYLIST_MAX_AGE=30000

# Включить проверку источника стрима (true | false, по умолчанию: true)
STREAM_SOURCE_CHECK_ENABLED=true

# Таймаут проверки источника в миллисекундах (по умолчанию: 3000)
STREAM_SOURCE_CHECK_TIMEOUT=3000

# Максимальное количество одновременных стримов (по умолчанию: 100)
STREAM_MAX_JOBS=100

# Таймаут для определения зависшего процесса в миллисекундах (по умолчанию: 60000 = 60 секунд)
STREAM_HUNG_PROCESS_TIMEOUT=60000

# Таймаут простоя стрима в миллисекундах (по умолчанию: 180000 = 3 минуты)
# Стрим закрывается если нет запросов в течение этого времени
STREAM_IDLE_TIMEOUT_MS=180000

# Таймаут простоя preview стрима в миллисекундах (по умолчанию: 180000 = 3 минуты)
PREVIEW_STREAM_IDLE_TIMEOUT_MS=180000
